<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.gestionbibliotheque.Controller.EtudiantController">
    <children>
        <Label layoutX="18.0" layoutY="60.0" text="Matricule:">
            <font>
                <Font size="20.0" />
            </font>
        </Label>
        <Label layoutX="14.0" layoutY="117.0" text="Prenom:">
            <font>
                <Font size="20.0" />
            </font>
        </Label>
        <Label layoutX="14.0" layoutY="175.0" text="Nom:">
            <font>
                <Font size="20.0" />
            </font>
        </Label>
        <Label layoutX="12.0" layoutY="236.0" text="Email:">
            <font>
                <Font size="20.0" />
            </font>
        </Label>
        <TextField fx:id="txtMatricule" layoutX="14.0" layoutY="92.0" />
        <TextField fx:id="txtPrenom" layoutX="14.0" layoutY="149.0" />
        <TextField fx:id="txtNom" layoutX="14.0" layoutY="206.0" />
        <TextField fx:id="txtEmail" layoutX="14.0" layoutY="262.0" />
        <Button layoutX="62.0" layoutY="320.0" mnemonicParsing="false" onAction="#addStudent" text="Ajouter">
            <font>
                <Font size="20.0" />
            </font>
        </Button>
        <Label fx:id="message" layoutX="171.0" layoutY="219.0" prefHeight="17.0" prefWidth="0.0" textFill="RED" />
        <Label layoutX="232.0" text="Liste des Etudiants">
            <font>
                <Font name="System Bold" size="40.0" />
            </font></Label>
        <TableView fx:id="tableEtudiant" onMouseClicked="#getselectedStudent" layoutX="233.0" layoutY="75.0" prefHeight="200.0" prefWidth="562.0" style="-fx-background-color: black;">
            <columns>
                <TableColumn fx:id="colId" prefWidth="40" text="ID" />
                <TableColumn fx:id="colMatricule" prefWidth="60" text="Matricule" />
                <TableColumn fx:id="colNom" prefWidth="95" text="Nom" />
                <TableColumn fx:id="colPrenom" prefWidth="142" text="Prenom" />
                <TableColumn fx:id="colEmail" prefWidth="224" text="Email" />
            </columns>
        </TableView>
        <Button layoutX="356.0" layoutY="320.0" mnemonicParsing="false" onAction="#updateStudent" text="Modifier">
            <font>
                <Font size="20.0" />
            </font>
        </Button>
        <Button layoutX="627.0" layoutY="320.0" mnemonicParsing="false" onAction="#deleteStudentButton" text="Supprimer">
            <font>
                <Font size="20.0" />
            </font>
        </Button>
        <StackPane fx:id="stackPane" />
    </children>
</AnchorPane>
