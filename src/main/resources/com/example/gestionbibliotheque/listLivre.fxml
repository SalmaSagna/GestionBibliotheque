<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.gestionbibliotheque.Controller.LivreController">
   <children>
      <Label layoutX="159.0" text="Liste des Livres">
         <font>
            <Font name="System Bold" size="40.0" />
         </font></Label>
       <Label layoutX="17.0" layoutY="89.0" text="ISBN:">
           <font>
               <Font size="20.0" />
           </font>
       </Label>
       <Label layoutX="19.0" layoutY="152.0" text="Titre:">
           <font>
               <Font size="20.0" />
           </font>
       </Label>
       <Label layoutX="17.0" layoutY="204.0" text="Auteur:">
           <font>
               <Font size="20.0" />
           </font>
       </Label>
       <TextField fx:id="txtISBN" layoutX="19.0" layoutY="126.0" />
       <TextField fx:id="txtTitre" layoutX="19.0" layoutY="182.0" />
       <TextField fx:id="txtAuteur" layoutX="19.0" layoutY="236.0" />
       <Label fx:id="message" layoutX="171.0" layoutY="219.0" prefHeight="17.0" prefWidth="0.0" textFill="RED" />
      <TableView fx:id="tableLivre" layoutX="236.0" layoutY="99.0" onMouseClicked="#getselectedBook" prefHeight="249.0" prefWidth="544.0" style="-fx-background-color: black;">
        <columns>
          <TableColumn fx:id="colId" prefWidth="61.333343505859375" text="ID" />
          <TableColumn fx:id="colISBN" prefWidth="120.66667175292969" text="ISBN" />
            <TableColumn fx:id="colTitre" prefWidth="183.0" text="Titre" />
            <TableColumn fx:id="colAuteur" prefWidth="195.33334350585938" text="Auteur" />
        </columns>
      </TableView>
      <Button layoutX="572.0" layoutY="366.0" mnemonicParsing="false" onAction="#displayStudent" text="Emprunter">
         <font>
            <Font size="20.0" />
         </font>
      </Button>
       <Button layoutX="432.0" layoutY="366.0" mnemonicParsing="false" onAction="#addBook" text="Ajouter">
           <font>
               <Font size="20.0" />
           </font>
       </Button>
       <Button layoutX="260.0" layoutY="362.0" mnemonicParsing="false" onAction="#updateBook" text="Modifier">
           <font>
               <Font size="20.0" />
           </font>
       </Button>
      <VBox fx:id="vboxStudent" layoutX="7.0" layoutY="58.0" prefHeight="280.0" prefWidth="208.0" style="-fx-background-color: black;" visible="false" AnchorPane.bottomAnchor="20.0" AnchorPane.topAnchor="60.0">
          <Label layoutX="18.0" layoutY="90.0" text="Info Emprunt:" textFill="WHITE">
              <font>
                  <Font name="System Bold" size="30.0" />
              </font>
          </Label>
          <Label layoutX="14.0" layoutY="210.0" text="ISBN:" textFill="WHITE">
              <font>
                  <Font size="20.0" />
              </font>
          </Label>
          <TextField fx:id="txtISBNEmprunt" editable="false" layoutX="14.0" layoutY="180.0" />
          <Label layoutX="18.0" layoutY="150.0" text="Matricule Etudiant:" textFill="WHITE">
              <font>
                  <Font size="20.0" />
              </font>
          </Label>
          <ComboBox fx:id="comboMatricule" onAction="#inputStudent" prefWidth="200.0" />
          <Label layoutX="14.0" layoutY="210.0" text="Prenom:" textFill="WHITE">
              <font>
                  <Font size="20.0" />
              </font>
          </Label>
          <TextField fx:id="txtPrenom" editable="false" layoutX="14.0" layoutY="180.0" />
          <Label layoutX="14.0" layoutY="270.0" text="Nom:" textFill="WHITE">
              <font>
                  <Font size="20.0" />
              </font>
          </Label>
          <TextField fx:id="txtNom" editable="false" layoutX="14.0" layoutY="240.0" />
          <Label layoutX="12.0" layoutY="330.0" text="Email:" textFill="WHITE">
              <font>
                  <Font size="20.0" />
              </font>
          </Label>
          <TextField fx:id="txtEmail" editable="false" layoutX="14.0" layoutY="300.0" />
          <Label text="Date de retour:" textFill="WHITE">
            <font>
               <Font size="20.0" />
            </font></Label>
          <DatePicker fx:id="dateRetour" />
          <Button mnemonicParsing="false" onAction="#confirmEmprunt" style="-fx-background-color: green;" text="Confirmer l'Emprunt" textFill="WHITE">
            <VBox.margin>
               <Insets bottom="10.0" left="35.0" top="10.0" />
            </VBox.margin>
            <font>
               <Font size="14.0" />
            </font>
          </Button>
      </VBox>
       <RadioButton fx:id="rbDisponibilite" layoutX="236.0" layoutY="73.0" mnemonicParsing="false" onAction="#showLivreDisponibilite" text="Disponible" />
       <RadioButton fx:id="rbNonDisponibilite" layoutX="348.0" layoutY="73.0" mnemonicParsing="false" onAction="#showLivreDisponibilite" text="Non Disponible" />
   </children>
</AnchorPane>
